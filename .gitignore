# Android / Gradle build output
/build
**/build/
.gradle/
.kotlin/
/captures
.externalNativeBuild
.cxx/

# Local configuration (machine-specific, contains SDK path)
/local.properties

# Signing — never commit keystores or their credentials
*.jks
*.keystore
keystore.properties

# Build artifacts
*.apk
*.aab

# IDE / project files
*.iml
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
/.idea/deploymentTargetSelector.xml

# OS / tooling junk
.DS_Store
.claude/

# NOTE: app/schemas/ is intentionally NOT ignored.
# Room exported schemas are the source of truth for future migrations.
